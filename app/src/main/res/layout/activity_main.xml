<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <Button
            android:id="@+id/btnPickPhoto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/pick_photo" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/original_image"
            android:textSize="16sp" />

        <ImageView
            android:id="@+id/ivOriginal"
            android:layout_width="match_parent"
            android:layout_height="260dp"
            android:layout_marginTop="8dp"
            android:background="#1A000000"
            android:contentDescription="@string/original_image"
            android:scaleType="centerCrop" />

        <Button
            android:id="@+id/btnCropUri"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/crop_from_uri" />

        <Button
            android:id="@+id/btnCropFile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/crop_from_file" />

        <Button
            android:id="@+id/btnCropNetImage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/crop_from_url" />

        <Button
            android:id="@+id/btnCropCircle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/crop_circle" />

        <Button
            android:id="@+id/btnCropCompose"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/crop_with_compose" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/cropped_image"
            android:textSize="16sp" />

        <ImageView
            android:id="@+id/ivCropped"
            android:layout_width="match_parent"
            android:layout_height="260dp"
            android:layout_marginTop="8dp"
            android:background="#1A000000"
            android:contentDescription="@string/cropped_image"
            android:scaleType="fitCenter" />
    </LinearLayout>
</ScrollView>
